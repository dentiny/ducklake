# name: test/sql/constraints/not_null_nested_types.test
# description: test NOT NULL constraint on nested types (STRUCT, LIST, MAP)
# group: [constraints]

require ducklake

require parquet

test-env DUCKLAKE_CONNECTION __TEST_DIR__/{UUID}.db

test-env DATA_PATH __TEST_DIR__

statement ok
ATTACH 'ducklake:${DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '${DATA_PATH}/ducklake_not_null_nested_files')

# -----------------------------------------------
# STRUCT column with NOT NULL
# -----------------------------------------------
statement ok
CREATE TABLE ducklake.struct_tbl(id INTEGER, s STRUCT(a INTEGER, b INTEGER) NOT NULL);

# inserting a non-null struct should succeed
statement ok
INSERT INTO ducklake.struct_tbl VALUES (1, ROW(10, 20));

# inserting a NULL struct should fail
statement error
INSERT INTO ducklake.struct_tbl VALUES (2, NULL);
----
NOT NULL constraint failed

query II
SELECT * FROM ducklake.struct_tbl
----
1	{'a': 10, 'b': 20}

# struct with NULL children should be fine (the struct itself is not null)
statement ok
INSERT INTO ducklake.struct_tbl VALUES (3, ROW(NULL, NULL));

query II
SELECT * FROM ducklake.struct_tbl ORDER BY id
----
1	{'a': 10, 'b': 20}
3	{'a': NULL, 'b': NULL}

# -----------------------------------------------
# LIST column with NOT NULL
# -----------------------------------------------
statement ok
CREATE TABLE ducklake.list_tbl(id INTEGER, l INTEGER[] NOT NULL);

statement ok
INSERT INTO ducklake.list_tbl VALUES (1, [10, 20]);

statement error
INSERT INTO ducklake.list_tbl VALUES (2, NULL);
----
NOT NULL constraint failed

# empty list is fine (the list itself is not null)
statement ok
INSERT INTO ducklake.list_tbl VALUES (3, []);

query II
SELECT * FROM ducklake.list_tbl ORDER BY id
----
1	[10, 20]
3	[]

# -----------------------------------------------
# MAP column with NOT NULL
# -----------------------------------------------
statement ok
CREATE TABLE ducklake.map_tbl(id INTEGER, m MAP(VARCHAR, INTEGER) NOT NULL);

statement ok
INSERT INTO ducklake.map_tbl VALUES (1, MAP {'key': 42});

statement error
INSERT INTO ducklake.map_tbl VALUES (2, NULL);
----
NOT NULL constraint failed

query II
SELECT * FROM ducklake.map_tbl ORDER BY id
----
1	{key=42}

# -----------------------------------------------
# Verify NOT NULL shows correctly in DESCRIBE
# -----------------------------------------------
query IIIIII
DESCRIBE ducklake.struct_tbl
----
id	INTEGER	YES	NULL	NULL	NULL
s	STRUCT(a INTEGER, b INTEGER)	NO	NULL	NULL	NULL
